<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@id/content"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2.0dip"
    android:clickable="true"
    android:focusable="true"
    app:cardElevation="2.0dip">

    <LinearLayout
        android:id="@id/content_lin"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:focusable="true"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@id/selected_view"
            android:layout_width="8.0dip"
            android:layout_height="fill_parent"
            android:background="?colorPrimary"
            android:orientation="horizontal"
            android:visibility="invisible" />

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:nextFocusRight="@id/edit"
            android:orientation="vertical">

            <LinearLayout
                android:id="@id/container"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1.0"
                    android:gravity="center_vertical"
                    android:paddingLeft="2.0dip">

                    <TextView
                        android:id="@id/profile_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?android:textAppearanceSmall"
                        android:textColor="?colorOnSurface"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@id/edit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="@string/edit"
                    android:focusable="true"
                    android:paddingLeft="2.0dip"
                    android:paddingTop="2.0dip"
                    android:paddingRight="2.0dip"
                    android:paddingBottom="2.0dip"
                    app:srcCompat="@drawable/ic_image_edit" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/url_test"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="@string/connection_test_url_test"
                    android:focusable="true"
                    android:paddingLeft="2.0dip"
                    android:paddingTop="2.0dip"
                    android:paddingRight="2.0dip"
                    android:paddingBottom="2.0dip"
                    app:srcCompat="@drawable/ic_baseline_shutter_speed_24" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@id/double_column_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="@string/edit"
                    android:focusable="true"
                    android:padding="12.0dip"
                    android:visibility="gone"
                    app:srcCompat="@drawable/ic_baseline_more_vert_24" />

                <LinearLayout
                    android:id="@id/share"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="@string/share"
                    android:focusable="true"
                    android:nextFocusLeft="@id/container">

                    <LinearLayout
                        android:id="@id/share_layer"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:padding="2.0dip">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@id/shareIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:srcCompat="@drawable/ic_social_share" />
                    </LinearLayout>
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@id/remove"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="@string/delete"
                    android:focusable="true"
                    android:paddingLeft="2.0dip"
                    android:paddingTop="2.0dip"
                    android:paddingRight="2.0dip"
                    android:paddingBottom="2.0dip"
                    android:visibility="gone"
                    app:srcCompat="@drawable/ic_action_delete" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:paddingStart="2.0dip"
                android:paddingEnd="8.0dip"
                android:paddingBottom="2.0dip">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@id/profile_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?android:textAppearanceSmall"
                        android:textColor="?accentOrTextSecondary"
                        android:textSize="10.0sp" />

                    <TextView
                        android:id="@id/profile_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2.0dip"
                        android:maxLength="35"
                        android:singleLine="true"
                        android:textAppearance="?android:textAppearanceSmall"
                        android:textColor="?accentOrTextSecondary"
                        android:textSize="10.0sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8.0dip"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:id="@id/profile_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLength="28"
                        android:singleLine="true"
                        android:text="@string/server_address"
                        android:textAppearance="?android:textAppearanceSmall"
                        android:textColor="?colorPrimary"
                        android:textSize="10.0sp" />

                    <TextView
                        android:id="@id/traffic_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8.0dip"
                        android:text="@string/traffic"
                        android:textAppearance="?android:textAppearanceSmall"
                        android:textColor="?colorPrimary"
                        android:textSize="10.0sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
